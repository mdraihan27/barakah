# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=Barakah
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=True

# =============================================================================
# Server
# =============================================================================
HOST=0.0.0.0
PORT=8000

# =============================================================================
# MongoDB
# =============================================================================
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=barakah_db

# =============================================================================
# JWT Authentication
# =============================================================================
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Google OAuth 2.0
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# =============================================================================
# Email (SMTP)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM_NAME=Barakah
EMAIL_FROM_ADDRESS=noreply@barakah.com

# =============================================================================
# Verification & Reset Codes
# =============================================================================
VERIFICATION_CODE_EXPIRE_MINUTES=15
RESET_CODE_EXPIRE_MINUTES=15

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# =============================================================================
# Uploads
# =============================================================================
UPLOAD_DIR=uploads
MAX_IMAGE_SIZE_MB=5
